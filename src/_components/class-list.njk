<section id="locations" class="section locations" aria-labelledby="locations-title">
  <div class="container">
    <header class="section__head">
      <h2 id="locations-title">Where classes meet</h2>
    </header>

    <ul class="locations__list" role="list">
      {% for place in cities %}
        <li class="location-card">
          <h3 class="location-card__title">
            {{ place.city }}{% if place.region %}, {{ place.region }}{% endif %}
          </h3>
          {% if place.venueName %}
            <p class="location-card__venue">{{ place.venueName }}</p>
          {% endif %}
          <address class="location-card__address">
            {% for line in place.addressLines %}
              {{ line }}{% if not loop.last %}<br />{% endif %}
            {% endfor %}
          </address>
          <p class="location-card__actions">
            <a class="location-card__link location-card__link--primary" href="/local-classes/{{ place.slug }}/">
              Location details
            </a>
            {% if place.mapUrl %}
              <a class="location-card__link" href="{{ place.mapUrl }}" rel="noopener noreferrer">Open in Maps</a>
            {% endif %}
          </p>
        </li>
      {% endfor %}
    </ul>

    <aside class="locations__virtual" aria-labelledby="virtual-option-title">
      <h3 id="virtual-option-title">Can’t attend in person?</h3>
      <p>
        Join online instead. We send a link so you can participate remotely from wherever you are.
      </p>
      <p class="locations__virtual-actions">
        <a class="btn btn--primary" href="/virtual-classes/#virtual-signup">Sign up for the virtual link</a>
      </p>
    </aside>
  </div>
</section>
