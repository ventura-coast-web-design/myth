<section id="videos" class="section videos" aria-labelledby="videos-title">
  <div class="container">
    <header class="section__head">
      <h2 id="videos-title">Watch the Videos</h2>
      <p>Choose a session to follow along with the class material.</p>
    </header>

    {%- set videos = [
      { "title": "Demons aren't what you think", "id": "EXqtpw8-KZE?pp=0gcJCdkKAYcqIYzv" },
      { "title": "The Serpent and the Promise", "id": "-GF2Judmm2U" },
      { "title": "Lucifer and Misread Prophecy", "id": "2R8qmJH_p_4" },
      { "title": "Satan in Job and Zechariah", "id": "KKtjLxcgJ64" },
      { "title": "The New Testament's Use of Satan", "id": "P81E_5MLcDM" },
      { "title": "Hope, Resurrection, and Kingdom", "id": "IGbjT0MQ-Ew" }
    ] -%}

    <div class="videos__grid">
      {%- for v in videos %}
        <article class="video-card">
          <div class="video-card__embed">
            <iframe
              src="https://www.youtube.com/embed/{{ v.id }}"
              title="{{ v.title }}"
              loading="lazy"
              referrerpolicy="strict-origin-when-cross-origin"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
          <p class="video-card__title">{{ v.title }}</p>
        </article>
      {%- endfor %}
    </div>
  </div>
</section>
